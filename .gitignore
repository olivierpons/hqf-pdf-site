# Python
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
build/
dist/

# Virtualenvs
.venv/
venv/
env/

# Django
*.log
db.sqlite3
db.sqlite3-journal
/media/
/staticfiles/

# Compiled translations: .po is the source and is versioned, .mo is a build
# artefact rebuilt by compilemessages.
*.mo

# Local configuration: the real TOML carries the secret key and machine paths.
# It normally lives at ~/.config/hqf_pdf_site.toml, outside the repo; these
# patterns cover the in-repo copies TOML_CONFIG_FILE gets pointed at.
/hqf_pdf_site.toml
/local.toml
/install/*.toml
!install/config_template.toml

# Tests and coverage
.pytest_cache/
.coverage
htmlcov/
.ruff_cache/

# PyCharm: everything is local except the shared inspection profile, which is
# versioned so the IDE flags what the linters flag.
.idea/*
!.idea/inspectionProfiles/
.idea/inspectionProfiles/*
!.idea/inspectionProfiles/Project_Default.xml
!.idea/inspectionProfiles/profiles_settings.xml

# OS
.DS_Store

# uv writes the venv here; uv.lock is versioned.
.python-version
