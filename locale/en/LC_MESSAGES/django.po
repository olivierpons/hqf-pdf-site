msgstr "Styled runs inside a paragraph"

#: examples/catalog.py:365
msgid "[A paragraph whose style changes inside it: size, underline, colour.]"
msgstr "A paragraph whose style changes inside it: size, underline, colour."

#: examples/catalog.py:374
msgid "[Stamps fitted to a box]"
msgstr "Stamps fitted to a box"

#: examples/catalog.py:376
msgid ""
"[What a document says about itself — DRAFT, COPY, PAID — laid across boxes "
"of four different shapes and scaled to each.]"
msgstr ""
"What a document says about itself — DRAFT, COPY, PAID — laid across boxes of "
"four different shapes and scaled to each."

#: examples/catalog.py:386
msgid "[Shrunk headings and a turned label]"
msgstr "Shrunk headings and a turned label"

#: examples/catalog.py:388
msgid ""
"[Headings of different lengths shrunk to share one column, and a label "
"turned a quarter turn up the page's spine.]"
msgstr ""
"Headings of different lengths shrunk to share one column, and a label turned "
"a quarter turn up the page's spine."

#: examples/catalog.py:398
msgid "[A multi-page invoice table]"
msgstr "A multi-page invoice table"

#: examples/catalog.py:400
msgid "[An invoice table, laid out across as many pages as its lines need.]"
msgstr "An invoice table, laid out across as many pages as its lines need."

#: examples/catalog.py:409
msgid "[Cell margin, border, padding and fill]"
msgstr "Cell margin, border, padding and fill"

#: examples/catalog.py:411
msgid "[What a cell can do with its own box: margin, border, padding, fill.]"
msgstr "What a cell can do with its own box: margin, border, padding, fill."

#: examples/catalog.py:420
msgid "[Coloured cell borders and fills]"
msgstr "Coloured cell borders and fills"

#: examples/catalog.py:422
msgid ""
"[A cell's four sides in four different colours, and coloured fills told "
"apart from coloured borders.]"
msgstr ""
"A cell's four sides in four different colours, and coloured fills told apart "
"from coloured borders."

#: examples/catalog.py:432
msgid "[A self-paginating table]"
msgstr "A self-paginating table"

#: examples/catalog.py:434
msgid ""
"[A long table handed over whole, deciding its own pagination, its heading on "
"top of every page, its footnote under every page, its shading said once for "
"the whole table, and a note the caller draws under each page from the "
"geometry the placement gives it.]"
msgstr ""
"A long table handed over whole, deciding its own pagination, its heading on "
"top of every page, its footnote under every page, its shading said once for "
"the whole table, and a note the caller draws under each page from the "
"geometry the placement gives it."

#: examples/catalog.py:446
msgid "[Cells merged down the rows]"
msgstr "Cells merged down the rows"

#: examples/catalog.py:448
msgid ""
"[A specification sheet whose cells are merged down the rows: each group "
"named once beside all of its rows, one note beside them, the hairlines "
"stopping at their edges, and a note too long for the rows it covers growing "
"the last of them.]"
msgstr ""
"A specification sheet whose cells are merged down the rows: each group named "
"once beside all of its rows, one note beside them, the hairlines stopping at "
"their edges, and a note too long for the rows it covers growing the last of "
"them."

#: examples/catalog.py:460
msgid "[Columns measured from their cells]"
msgstr "Columns measured from their cells"

#: examples/catalog.py:462
msgid ""
"[One parts list twice: four columns sharing the width equally, then the "
"reference, the quantity and the price each as wide as their own widest cell "
"and the description given everything they leave.]"
msgstr ""
"One parts list twice: four columns sharing the width equally, then the "
"reference, the quantity and the price each as wide as their own widest "
"cell and the description given everything they leave."

