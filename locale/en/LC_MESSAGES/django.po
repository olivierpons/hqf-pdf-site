#: core/management/commands/rewrap_comments.py:193
msgid "[Re-flow narrow comment blocks at the project line width.]"
msgstr "Re-flow narrow comment blocks at the project line width."

#: core/management/commands/rewrap_comments.py:196
msgid ""
"[Rewrap comment blocks to project width. Use --help for full documentation.]"
msgstr ""
"Rewrap comment blocks to project width. Use --help for full documentation."

#: core/management/commands/rewrap_comments.py:202
msgid ""
"[Walks the given paths, finds consecutive ``#``-comment blocks at the same "
"indent and rewraps each block to the target width. Bullets and numbered list "
"items each stay on their own line. Skips shebangs, encoding lines, separator "
"decorations and tooling pragmas (noqa, type:, fmt:, pragma:, pylint:, "
"isort:). Idempotent and Black-stable.]"
msgstr ""
"Walks the given paths, finds consecutive ``#``-comment blocks at the same "
"indent and rewraps each block to the target width. Bullets and numbered list "
"items each stay on their own line. Skips shebangs, encoding lines, separator "
"decorations and tooling pragmas (noqa, type:, fmt:, pragma:, pylint:, "
"isort:). Idempotent and Black-stable."

#: core/management/commands/rewrap_comments.py:219
msgid ""
"[Files or directories. Defaults to the project app dirs (app, core, "
"websearch).]"
msgstr ""
"Files or directories. Defaults to the project app dirs (app, core, "
"websearch)."

#: core/management/commands/rewrap_comments.py:228
msgid "[Target maximum line width. Default: 88.]"
msgstr "Target maximum line width. Default: 88."

#: core/management/commands/rewrap_comments.py:236
msgid "[Allow line breaks at hyphens inside hyphenated words. Off by default.]"
msgstr "Allow line breaks at hyphens inside hyphenated words. Off by default."

#: core/management/commands/rewrap_comments.py:247
msgid ""
"[Substring filter. Any path containing this substring is skipped. "
"Repeatable.]"
msgstr ""
"Substring filter. Any path containing this substring is skipped. Repeatable."

#: core/management/commands/rewrap_comments.py:258
msgid "[Do not write changes; print a unified diff of what would change.]"
msgstr "Do not write changes; print a unified diff of what would change."

#: core/management/commands/rewrap_comments.py:269
msgid ""
"[Exit code 1 if any file would change. Implies --dry-run. Useful for CI.]"
msgstr ""
"Exit code 1 if any file would change. Implies --dry-run. Useful for CI."

#: core/management/commands/rewrap_comments.py:286
msgid "[No Python files matched the given paths.]"
msgstr "No Python files matched the given paths."

#: core/management/commands/rewrap_comments.py:308
msgid "[--check: comment blocks need rewrapping.]"
msgstr "--check: comment blocks need rewrapping."

